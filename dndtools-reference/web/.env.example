# PostgreSQL connection string
DATABASE_URL="postgresql://dndtools:dndtools@localhost:5432/dndtools?schema=public"

# Secret for signing session nonces (generate with: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-random-32-byte-secret"

# Public site URL (sitemap chunks, robots, metadataBase, Open Graph)
SITE_URL="http://localhost:3000"
# Legacy alias — SITE_URL takes precedence
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Import script path override for Docker (data mounted at /data/dndtools)
# DATA_DIR=/data/dndtools
